void <<gentran(literal(eval(filename)))$>>::precalcConsts() {
<<block([i, j], 
    /* TODO: later the aux equations should be included in the length of used_pos_states */
    gentran(literal("    E.setZero()\;", cr)),
    j: 1,
    for i:1 thru length(used_pos_states) do (
        if used_pos_states[i] then (
