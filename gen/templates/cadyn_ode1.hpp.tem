    <<gentran(literal(eval(filename)))$>>();

    // Residual evaluation: f(x, xdot, u, t) = 0, writes f
    void evaluateResidual();

    // Jacobian blocks for residual: df/dx, df/dxdot, write f, df_dx, df_dxdot
    void evaluateResidualAndJacobians();

    // Input Jacobian, writes df_du
    void evaluateInputJacobian();

    // Output evaluation, writes y
    void evaluateOutput();

