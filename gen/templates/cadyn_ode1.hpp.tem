    gentran(literal("    public:", cr)),
    gentran(literal("        inputs_t(VecIn& u) : ")),
    for i:1 thru nbrin do (
        gentran(literal(eval(u[i]), "(u.data()[", eval(i-1), "])")),
        if i#nbrin then
            gentran(literal(", "))
    ),            
    gentran(literal(" {}", cr, cr)),
    for i:1 thru nbrin do (
        gentran(literal("        real_type &", eval(u[i]), "\;", cr))
    ),            
