<<block([i, j],
    load(cadyn_gen_util),
    file: sysdef@sys_rel@file,
    title: sysdef@sys_rel@name,
    nbrdof: sysdef@sys_rel@nbrdof,
    nbrin: sysdef@sys_rel@nbrin,
    nbrout: length(sysdef@outputs),
    inputs: sysdef@sys_rel@u,
    output_names: sysdef@sys_rel@out_names,
    u: sysdef@sys_rel@u,
    y: sysdef@outputs,
    external: sysdef@sys_rel@external,
    d_external: sysdef@sys_rel@d_external,
    params: sysdef@all_params,

    f: sysdef@f,

    /* Filter unused states */
    eliminate_dof_state: [],
    for i:1 thru nbrdof do (
        if freeof(sysdef@sys_rel@states[i], f) and freeof(sysdef@sys_rel@states[i], y) then
            eliminate_dof_state: endcons(true, eliminate_dof_state)
        else
            eliminate_dof_state: endcons(false, eliminate_dof_state)
    ),
    eliminate_dof_velo: [],
    for i:1 thru nbrdof do (
        if freeof(sysdef@sys_rel@states_dd[i], f) and freeof(sysdef@sys_rel@states_dd[i], y) then
            eliminate_dof_velo: endcons(true, eliminate_dof_velo)
        else
            eliminate_dof_velo: endcons(false, eliminate_dof_velo)
    ),

    ode1_II: f,
    nbrII : nbrdof,
    xII : [],
    xdot : [],
    for j:1 thru nbrdof do (
        if eliminate_dof_velo[j] then (
            xII: endcons(sysdef@sys_rel@states[j], xII),
            xdot: endcons(sysdef@sys_rel@states_d[j], xdot)
        ) else (
            xII: endcons(sysdef@sys_rel@states_d[j], xII),
            xdot: endcons(sysdef@sys_rel@states_dd[j], xdot)
        )
    ),
        
    used_pos_states : makelist(false, i, 1, nbrdof),
    nbrI : 0,
    xI : [],
    for i:1 thru nbrdof do (
        if not(eliminate_dof_velo[i]) and not(eliminate_dof_state[i]) then (
            used_pos_states[i]: true,
            nbrI : nbrI + 1,
            xI : endcons(sysdef@sys_rel@states[i], xI)
        )
    ),
    ode1_states : append(xI, xII),
    nbrstates: nbrI + nbrII,

    df_II_dx_I : simplify(jacobian(ode1_II, xI)),
    df_II_dx_II : simplify(jacobian(ode1_II, xII)),
    df_II_dxdot_II : simplify(jacobian(ode1_II, xdot)),

    df_II_du : simplify(jacobian(ode1_II, u)),
    dy_dx : simplify(jacobian(y, ode1_states)),
    dy_du : simplify(jacobian(y, u)),
    dy_dxdot : simplify(jacobian(y, xdot)),

    subst_list: [],
    subst_list: append(subst_list, makelist(xI[i]='x[i-1], i, 1, nbrI)),
    subst_list: append(subst_list, makelist(xII[i]='x[i-1+nbrI], i, 1, nbrII)),
    subst_list: append(subst_list, makelist(xdot[i]='xdot[i-1], i, 1, nbrII)),
        
    for i:1 thru nbrin do
        subst_list: endcons(sysdef@sys_rel@u[i]='u[i-1], subst_list),

    for i:1 thru length(sysdef@params) do
        subst_list: endcons(sysdef@params[i]=concat('param\., sysdef@params[i]), subst_list)

)$>><<gentran(literal("\/\* File generated form template cadyn_ode1.hpp.tem on ", eval(timedate()), ". Do not edit! \*\/", cr))$>>
<<gentran(literal("\/\* Multibody system: ", eval(title), " \*\/", cr))$>>

