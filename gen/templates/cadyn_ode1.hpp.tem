    void evaluateOutputJacobian();

    void precalcConsts();

<<block([], 
    if length(external) > 0 then (
        gentran(literal("    void calculateExternal()\;", cr)),
        gentran(literal("    void calculateExternalWithDeriv()\;", cr))
    )
)$>>

    <<gentran(literal(eval(filename), "Parameters"))$>> param;
    
    std::string name;
