    std::array<std::string, dimIn> in_name;
    std::array<std::string, dimOut> out_name;
    std::array<std::string, dimX> state_name;

<<block([i],

    /* Input index by name */
    gentran(literal(cr, "    typedef struct {", cr)),
    for i:1 thru nbrin do (
        gentran(literal("        int ", eval(u[i]), "\;", cr))
