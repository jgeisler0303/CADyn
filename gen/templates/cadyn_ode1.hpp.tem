    gentran(literal(cr)),
    genmat(opt[3], nbrII, nbrII, 0, 0, "df_II_dx_II", const_matrix_once),
    gentran(literal(cr)),
    genmat(opt[4], nbrII, nbrI, 0, 0, "df_II_dx_I", const_matrix_once),
    gentran(literal(cr)),

    for i:1 thru nbrdof do (
        i_: i-1,
