    gentran(literal("        states_t(VecX& x) : ")),
    for i:1 thru nbrstates do (
        gentran(literal(eval(ode1_states[i]), "(x.data()[", eval(i-1), "])")),
        if i#nbrstates then
            gentran(literal(", "))
    ),            
