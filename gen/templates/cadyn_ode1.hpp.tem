        gentran(literal(cr)),
        genmat(df_II_dxdot_II, nbrII, nbrII, 0, 0, "df_II_dxdot_II", 2),
        
        gentran(literal(cr)),
        genmat(df_II_du, nbrII, nbrin, 0, 0, "df_II_du", 2),
            
        gentran(literal(cr)),
        genmat(dy_dx, length(y), nbrstates, 0, 0, "dy_dx", 2),

        gentran(literal(cr)),
        genmat(dy_du, length(y), nbrin, 0, 0, "dy_du", 2),

